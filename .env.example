# ===========================================
# Google Workspace MCP for LibreChat
# Copy to LibreChat .env and add your keys
# ===========================================

# --- LibreChat (required) ---
MONGO_URI=mongodb://127.0.0.1:27017/LibreChat

# --- LLM API Key (add any provider LibreChat supports) ---
# Examples - add the ones you use:
# GEMINI_API_KEY=
# OPENROUTER_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Add any other provider key from LibreChat docs

# --- GCP OAuth (required for Google Workspace tools) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
