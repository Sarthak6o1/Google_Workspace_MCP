# ===========================================
# Google Workspace MCP for LibreChat
# Copy to LibreChat .env and add your keys
# ===========================================

# --- LibreChat (required) ---
MONGO_URI=mongodb://127.0.0.1:27017/LibreChat

# ===========================================
# LLM API Keys — pick one or more providers
# ===========================================
# See: https://docs.librechat.ai/configuration/librechat_yaml/ai_endpoints

# --- OpenAI (GPT-4, GPT-4o, o1, etc.) ---
# Built-in: no YAML needed. Add key and select OpenAI in LibreChat.
# OPENAI_API_KEY=

# --- Anthropic (Claude) ---
# Built-in: no YAML needed. Add key and select Anthropic in LibreChat.
# ANTHROPIC_API_KEY=

# --- Google / Gemini ---
# Built-in: no YAML needed. Use AI Studio key or Vertex AI (GOOGLE_SERVICE_KEY_FILE).
# GOOGLE_KEY=
# GEMINI_API_KEY=

# --- Azure OpenAI ---
# Requires librechat.yaml config under endpoints.azureOpenAI (see YAML example).
# For single resource, use env vars below. For multiple resources, use groups in YAML.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_INSTANCE_NAME=your-resource-name
# AZURE_OPENAI_API_DEPLOYMENT_NAME=your-deployment
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# --- AWS Bedrock ---
# BEDROCK_AWS_ACCESS_KEY_ID=
# BEDROCK_AWS_SECRET_ACCESS_KEY=
# BEDROCK_AWS_DEFAULT_REGION=us-east-1

# --- Custom endpoints (add to librechat.yaml endpoints.custom) ---
# OpenRouter (many models: Llama, Mistral, Claude, GPT, etc.)
# OPENROUTER_KEY=

# Groq
# GROQ_API_KEY=

# Mistral
# MISTRAL_API_KEY=

# Cohere
# COHERE_API_KEY=

# Perplexity
# PERPLEXITY_API_KEY=

# Together AI
# TOGETHERAI_API_KEY=

# Fireworks AI
# FIREWORKS_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# xAI (Grok)
# XAI_API_KEY=

# Hugging Face
# HUGGINGFACE_TOKEN=

# AnyScale
# ANYSCALE_API_KEY=

# Databricks
# DATABRICKS_API_KEY=

# ShuttleAI
# SHUTTLEAI_API_KEY=

# Unify
# UNIFY_API_KEY=

# Helicone (gateway to multiple providers)
# HELICONE_KEY=

# Portkey (gateway/proxy)
# PORTKEY_API_KEY=
# PORTKEY_OPENAI_VIRTUAL_KEY=

# APIPIE
# APIPIE_API_KEY=

# ===========================================
# GCP OAuth (required for Google Workspace tools)
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional: Custom OAuth redirect (default: http://localhost:8080/) ---
# Use for production or custom deployments. Must match GCP OAuth client config.
# GOOGLE_MCP_REDIRECT_URI=http://localhost:8080/
